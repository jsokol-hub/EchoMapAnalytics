# Copy to .env and fill in. Schema must match where dbt builds marts (see profiles.yml target schema).
ECHOMAP_DBT_SCHEMA=public

# Option A: full URL
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Option B: separate vars
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echomap
DB_USER=postgres
DB_PASSWORD=secret

# Optional dashboard tuning
# ECHOMAP_DASH_CACHE_SEC=600
# ECHOMAP_DASH_LOC_LIMIT=350
