# ──────────────────────────────────────────────────────────
# EchoMap Dashboard — environment configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# Schema where dbt materialises mart tables.
# Must match the target `schema` in `profiles.yml` (same DB you connect to here).
# If you see "relation ... does not exist", either this value is wrong or run `dbt run`.
ECHOMAP_DBT_SCHEMA=public

# ── Database connection (choose Option A or B) ───────────

# Option A: full SQLAlchemy URL (takes priority if set)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Option B: individual parameters
# CapRover/Docker: use host gateway, CapRover service host (srv-captain--appname), or LAN IP — not localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echomap
DB_USER=postgres
DB_PASSWORD=

# ── Dashboard tuning (optional) ──────────────────────────

# How long to cache data in memory (seconds). Default: 600 (10 min).
# ECHOMAP_DASH_CACHE_SEC=600

# Max location rows fetched from mart_location_summary. Default: 350.
# ECHOMAP_DASH_LOC_LIMIT=350
