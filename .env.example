# === SSH Tunnel (if DB is on a remote server) ===
SSH_ENABLED=true
SSH_HOST=your-server.com
SSH_PORT=22
SSH_USER=your_ssh_user
SSH_PASSWORD=
# Path to SSH private key (use forward slashes or double backslashes)
SSH_KEY_PATH=C:/Users/your_user/.ssh/id_rsa

# === PostgreSQL connection ===
# When using SSH tunnel, PG_HOST should be 127.0.0.1 or localhost
# (the tunnel forwards the remote port to a local port)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=telegram_news
PG_USER=postgres
PG_PASSWORD=your_password
# Remote PG port (the port PostgreSQL listens on inside the server)
PG_REMOTE_PORT=5432

# === Data ===
CSV_DATA_PATH=data/messages.csv
PG_TABLE_NAME=

# === Optional ===
HF_TOKEN=
